{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "aif-config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "1"
    },
    "profile": {
      "type": "string"
    },
    "adapters": {
      "type": "array",
      "items": {
        "enum": ["claude", "codex", "cursor", "copilot"]
      }
    }
  },
  "required": ["schemaVersion", "profile", "adapters"]
}
