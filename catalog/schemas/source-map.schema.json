{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:aif:schema:source-map:1",
  "title": "source-map",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1" },
    "metadataFormatVersion": { "const": "1" },
    "frameworkVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "adapterOutputVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$"
    },
    "adapterId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9:-]*$"
    },
    "canonicalSourceId": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": { "$ref": "#/$defs/projectPath" },
          "checksum": { "$ref": "#/$defs/checksum" },
          "sources": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "$ref": "#/$defs/projectPath" }
          },
          "ownership": { "enum": ["aif-owned-generated", "project-owned"] }
        },
        "required": ["path", "checksum", "sources", "ownership"]
      }
    }
  },
  "required": [
    "schemaVersion",
    "metadataFormatVersion",
    "frameworkVersion",
    "adapterOutputVersion",
    "adapterId",
    "canonicalSourceId",
    "files"
  ],
  "$defs": {
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*//).+$"
    },
    "checksum": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
