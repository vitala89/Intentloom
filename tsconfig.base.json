{
  "compilerOptions": {
    "paths": {
      "@intentloom/core": ["./packages/core/src/index.ts"],
      "@intentloom/adapters": ["./packages/adapters/src/index.ts"],
      "@intentloom/validator": ["./packages/validator/src/index.ts"],
      "@intentloom/protocol": ["./packages/protocol/src/index.ts"]
    },
    "types": ["node"],
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true
  }
}
