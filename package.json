{
  "name": "@intentloom/workspace",
  "version": "0.1.0-beta.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/sync-version.mjs && tsc -b && node scripts/build-cli.mjs && node scripts/build-daemon.mjs && node scripts/build-mcp.mjs",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "lint": "tsc -b --pretty false",
    "format:check": "prettier --check \"**/*.{ts,md,json,yaml,yml}\"",
    "pack:cli": "pnpm --filter ./packages/cli pack --pack-destination ./artifacts"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
